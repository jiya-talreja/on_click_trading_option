{
    "manifest_version":3,
    "name":"Trading-extension",
    "description":"instant buying and selling for trading with trading-view",
    "version":"1.0",
    "permissions":["activeTab"],
    "content_scripts":[{
        "matches":[ "https://*.tradingview.com/*"],
        "js":["watcher.js"]
    }
    ],
    "host_permissions": [
    "https://*.tradingview.com/*"
]
}
